{
  "entities": {
    "DutyLog": {
      "title": "Duty Log",
      "description": "Operational issues and incident tracking.",
      "type": "object",
      "properties": {
        "case_id": { "type": "string", "description": "Unique readable ID" },
        "created_at": { "type": "string", "format": "date-time" },
        "shift": { "type": "string", "enum": ["AM", "PM", "Night"] },
        "room_number": { "type": "string" },
        "guest_name": { "type": "string" },
        "issue_type": { "type": "string" },
        "priority": { "type": "string", "enum": ["Low", "Medium", "High", "Critical"] },
        "description": { "type": "string" },
        "action_taken": { "type": "string" },
        "owner": { "type": "string", "description": "Staff ID" },
        "status": { "type": "string", "enum": ["Open", "In Progress", "Pending", "Resolved"] },
        "follow_up_required": { "type": "boolean" },
        "resolved_at": { "type": "string", "format": "date-time" }
      },
      "required": ["case_id", "created_at", "shift", "issue_type", "priority", "status", "owner"]
    },
    "HandoverNote": {
      "title": "Handover Note",
      "description": "Shift transition summaries.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "from_shift": { "type": "string", "enum": ["AM", "PM", "Night"] },
        "to_shift": { "type": "string", "enum": ["AM", "PM", "Night"] },
        "notes": { "type": "string" },
        "unresolved_case_ids": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["date", "from_shift", "to_shift", "notes", "unresolved_case_ids"]
    },
    "ShiftChecklist": {
      "title": "Shift Checklist",
      "description": "Tasks required for specific shifts.",
      "type": "object",
      "properties": {
        "task_name": { "type": "string" },
        "category": { "type": "string" },
        "shift": { "type": "string", "enum": ["AM", "PM", "Night"] },
        "required": { "type": "boolean" },
        "completed": { "type": "boolean" },
        "completed_by": { "type": "string" },
        "completed_at": { "type": "string", "format": "date-time" }
      },
      "required": ["task_name", "category", "shift", "required", "completed"]
    },
    "StaffMember": {
      "title": "Staff Member",
      "description": "Authorized staff profile with granular RBAC permissions.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "Duty Manager", "Department Lead", "Staff", "Viewer"] },
        "department": { "type": "string", "enum": ["Front Office", "Housekeeping", "Maintenance", "Security", "Management"] },
        "email": { "type": "string", "format": "email" },
        "permissions": {
          "type": "object",
          "properties": {
            "view_all_cases": { "type": "boolean" },
            "view_department_cases": { "type": "boolean" },
            "create_cases": { "type": "boolean" },
            "edit_own_cases": { "type": "boolean" },
            "edit_all_cases": { "type": "boolean" },
            "resolve_cases": { "type": "boolean" },
            "assign_cases": { "type": "boolean" },
            "submit_handover": { "type": "boolean" },
            "complete_checklist": { "type": "boolean" },
            "manage_staff": { "type": "boolean" },
            "view_audit_logs": { "type": "boolean" },
            "manage_settings": { "type": "boolean" }
          }
        },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "role", "department", "email", "permissions"]
    },
    "DutyLog": {
      "title": "Duty Log",
      "description": "Incident record.",
      "type": "object",
      "properties": {
        "case_id": { "type": "string" },
        "room_number": { "type": "string" },
        "guest_name": { "type": "string" },
        "issue_type": { "type": "string" },
        "department": { "type": "string" },
        "priority": { "type": "string" },
        "description": { "type": "string" },
        "action_taken": { "type": "string" },
        "owner": { "type": "string" },
        "owner_id": { "type": "string" },
        "status": { "type": "string" },
        "created_at": { "type": "string" }
      }
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "Records of critical changes for accountability.",
      "type": "object",
      "properties": {
        "target_id": { "type": "string" },
        "collection": { "type": "string" },
        "changed_by": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "action": { "type": "string", "enum": ["create", "update", "delete"] },
        "changes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "field": { "type": "string" },
              "old_value": { "type": "any" },
              "new_value": { "type": "any" }
            }
          }
        }
      },
      "required": ["target_id", "collection", "changed_by", "timestamp", "action"]
    }
  },
  "firestore": {
    "duty_logs": {
      "schema": "DutyLog",
      "description": "Main incident tracking collection"
    },
    "handover_notes": {
      "schema": "HandoverNote",
      "description": "Shift transition logs"
    },
    "checklists": {
      "schema": "ShiftChecklist",
      "description": "Daily operational tasks"
    },
    "staffMembers": {
      "schema": "StaffMember",
      "description": "Authorized RBAC staff directory"
    },
    "audit_logs": {
      "schema": "AuditLog",
      "description": "Audit trail for system operations"
    }
  }
}
