rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Primitives ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Verifies the user has a registered staff profile
    function isStaff() {
      return isSignedIn() && exists(/databases/$(database)/documents/staffMembers/$(request.auth.uid));
    }

    // Safely retrieves the current user's staff profile data
    function getStaffData() {
      return get(/databases/$(database)/documents/staffMembers/$(request.auth.uid)).data;
    }

    // --- Collection: staffMembers ---
    match /staffMembers/{staffId} {
      // Users can always read their own profile to bootstrap context
      allow read: if isSignedIn() && request.auth.uid == staffId;
      
      // Staff management restricted to those with manage_staff permission
      allow list: if isStaff() && getStaffData().permissions.get('manage_staff', false) == true;
      
      allow create: if isSignedIn() && (
        // Self-provisioning (bootstrap) if no profile exists
        (!exists(/databases/$(database)/documents/staffMembers/$(request.auth.uid)) && request.auth.uid == staffId) ||
        // Admin provisioning
        (isStaff() && getStaffData().permissions.get('manage_staff', false) == true)
      );
      
      allow update: if isStaff() && (
        // Self-update for metadata
        (request.auth.uid == staffId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'email'])) ||
        // Admin update for roles/permissions
        (getStaffData().permissions.get('manage_staff', false) == true)
      );
      
      allow delete: if isStaff() && getStaffData().permissions.get('manage_staff', false) == true;
    }

    // --- Collection: duty_logs ---
    match /duty_logs/{logId} {
      // Read access based on permissions or ownership
      allow read: if isStaff() && (
        getStaffData().permissions.get('view_all_cases', false) == true ||
        resource.data.get('department', null) == getStaffData().get('department', null) ||
        resource.data.owner_id == request.auth.uid
      );
      
      // Create access
      allow create: if isStaff() && 
                    getStaffData().permissions.get('create_cases', false) == true && 
                    request.resource.data.owner_id == request.auth.uid &&
                    request.resource.data.created_at == request.time;
      
      // Update access based on role-tiered logic
      allow update: if isStaff() && (
        // Tier 1: Admin edit all
        getStaffData().permissions.get('edit_all_cases', false) == true ||
        // Tier 2: Owner edit own
        (getStaffData().permissions.get('edit_own_cases', false) == true && resource.data.owner_id == request.auth.uid) ||
        // Tier 3: Restricted status resolution
        (getStaffData().permissions.get('resolve_cases', false) == true && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'resolved_at']))
      );
      
      allow delete: if isStaff() && getStaffData().permissions.get('manage_settings', false) == true;
    }

    // --- Collection: audit_logs ---
    match /audit_logs/{auditId} {
      // Only authorized personnel can view the audit trail
      allow list, get: if isStaff() && getStaffData().permissions.get('view_audit_logs', false) == true;
      
      // Any staff member can create an audit log (e.g., when they modify a record)
      allow create: if isStaff();
      
      allow update, delete: if false; // Immutable ledger
    }

    // --- Collection: checklists ---
    match /checklists/{taskId} {
      allow read: if isStaff();
      
      allow update: if isStaff() && (
        getStaffData().permissions.get('complete_checklist', false) == true ||
        getStaffData().permissions.get('manage_checklists', false) == true ||
        getStaffData().permissions.get('manage_settings', false) == true
      );
      
      allow create, delete: if isStaff() && (
        getStaffData().permissions.get('manage_checklists', false) == true ||
        getStaffData().permissions.get('manage_settings', false) == true
      );
    }

    // --- Collection: handover_notes ---
    match /handover_notes/{noteId} {
      allow read: if isStaff();
      
      allow create: if isStaff() && getStaffData().permissions.get('submit_handover', false) == true;
    }
  }
}
